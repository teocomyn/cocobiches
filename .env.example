# URL publique du site (sitemap, métadonnées, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.cocobiches.fr

# E-mails transactionnels (Resend — https://resend.com)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Cocobiches <bonjour@cocobiches.com>
# CONTACT_TO_EMAIL=bonjour@cocobiches.com
# NEWSLETTER_TO_EMAIL=bonjour@cocobiches.com
# SEMINAIRE_TO_EMAIL=events.hoteljdp.versailles@gmail.com

# Newsletter (Brevo — alternative au webhook)
# BREVO_API_KEY=xkeysib-...
# BREVO_LIST_ID=2

# Webhooks optionnels (Slack, Make, Zapier…) si pas de Resend/Brevo
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/...
# NEWSLETTER_WEBHOOK_URL=https://...

# Plausible (analytics sans cookies) : laisser vide pour désactiver
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=cocobiches.fr
